{
  "name": "strict-explicit-publish",
  "version": "1.0.0",
  "description": "Quartz v5 filter that publishes only YAML Boolean publish: true.",
  "type": "module",
  "license": "MIT",
  "private": true,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "build": "tsup"
  },
  "dependencies": {
    "@quartz-community/types": "github:quartz-community/types"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  },
  "quartz": {
    "name": "strict-explicit-publish",
    "displayName": "Strict Explicit Publish",
    "category": "filter",
    "version": "1.0.0",
    "quartzVersion": ">=5.0.0",
    "dependencies": [],
    "defaultOrder": 50,
    "defaultEnabled": true,
    "defaultOptions": {}
  },
  "engines": {
    "node": ">=22",
    "npm": ">=10.9.2"
  }
}
